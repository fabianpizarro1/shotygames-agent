<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.shotygames.dropi-refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/user/dropi-refresh.sh</string>
    </array>

    <!-- Correr cada 6 horas (21600 segundos) -->
    <key>StartInterval</key>
    <integer>21600</integer>

    <!-- También correr al encender el Mac -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/user/dropi-refresh.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/user/dropi-refresh.log</string>
</dict>
</plist>
